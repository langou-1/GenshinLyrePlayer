<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GenshinLyrePlayer.ViewModels"
        xmlns:ctl="using:GenshinLyrePlayer.Controls"
        xmlns:models="using:GenshinLyrePlayer.Models"
        x:Class="GenshinLyrePlayer.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="原神琴自动演奏"
        Width="1260" Height="720"
        MinWidth="1260" MinHeight="540">

    <Window.Styles>
        <Style Selector="Button.toolbar">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#1f222a"/>
            <Setter Property="BorderBrush" Value="#2a2d36"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <!-- 轨道头 Mute / Solo 切换按钮（共用尺寸样式） -->
        <Style Selector="ToggleButton.trackToggle">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <!-- Mute：选中时红色 -->
        <Style Selector="ToggleButton.mute:checked">
            <Setter Property="Background" Value="#e35555"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- Solo：选中时紫色（参考 TuneLab 的配色 #8754FF） -->
        <Style Selector="ToggleButton.solo:checked">
            <Setter Property="Background" Value="#8754ff"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <DockPanel>

        <!-- 顶部工具栏 -->
        <Border Classes="panel" DockPanel.Dock="Top">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <Button Classes="toolbar" Content="📂 导入 MIDI" Click="OnOpenClicked"/>
                <Rectangle Width="1" Fill="#333" Margin="4,4"/>

                <TextBlock Text="乐器组:" VerticalAlignment="Center" Margin="4,0"/>
                <ComboBox ItemsSource="{Binding AvailableInstrumentGroups}"
                          SelectedItem="{Binding SelectedInstrumentGroup}"
                          MinWidth="200" VerticalAlignment="Center"
                          ToolTip.Tip="选择要模拟的原神琴类乐器组（组内乐器键位完全一致）。自动移调时若当前组无法完整覆盖所有音，会尝试切换到其它组。">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#9aa"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Rectangle Width="1" Fill="#333" Margin="4,4"/>
                <Button Classes="toolbar" MinWidth="110"
                        Content="{Binding PlayPauseButtonText}"
                        Command="{Binding TogglePlayPauseCommand}"
                        ToolTip.Tip="{Binding PlayPauseButtonTooltip}"/>
                <Rectangle Width="1" Fill="#333" Margin="4,4"/>

                <TextBlock Text="移调:" VerticalAlignment="Center" Margin="4,0"/>
                <Button Classes="toolbar" Content="−" Command="{Binding TransposeDownCommand}" Width="36"/>
                <TextBlock Text="{Binding Transpose, StringFormat={}{0:+#;-#;0}}"
                           VerticalAlignment="Center" MinWidth="28" HorizontalAlignment="Center"/>
                <Button Classes="toolbar" Content="+" Command="{Binding TransposeUpCommand}" Width="36"/>
                <Button Classes="toolbar" Content="自动" Command="{Binding AutoTransposeCommand}"/>

                <Rectangle Width="1" Fill="#333" Margin="4,4"/>
                <TextBlock Text="倒计时(秒):" VerticalAlignment="Center" Margin="4,0"/>
                <NumericUpDown Value="{Binding CountdownSeconds}" Minimum="0" Maximum="10"
                               Increment="1" FormatString="0" Width="100"/>
            </StackPanel>
        </Border>

        <!-- 底部状态栏 -->
        <Border Classes="panel" DockPanel.Dock="Bottom"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <TextBlock Text="{Binding FileName, FallbackValue='(未加载文件)', TargetNullValue='(未加载文件)'}"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusText}" Foreground="#9aa"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding TotalNotes, StringFormat='音符: {0}'}" Margin="10,0"/>
                <TextBlock Grid.Column="2" Foreground="#5cc88c"
                           Text="{Binding SupportedNotes, StringFormat='可演奏: {0}'}" Margin="10,0"/>
                <TextBlock Grid.Column="3" Foreground="#e35555"
                           Text="{Binding UnsupportedNotes, StringFormat='不支持: {0}'}" Margin="10,0"/>
            </Grid>
        </Border>

        <!-- 时间线 -->
        <Border DockPanel.Dock="Bottom" Background="#17191f" Padding="10,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Text="{Binding PlayheadText}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Slider Grid.Column="1" Minimum="0" Maximum="{Binding Duration}"
                        Value="{Binding Playhead}" Name="TimelineSlider"
                        PointerReleased="OnTimelineReleased"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding CountdownText}" Foreground="#ffd250"
                           FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>

        <!-- 多轨缩略图（固定在钢琴卷帘上方）。第一条是固定的“速度轨”，
             用来展示 SetTempo 标签 + 整体倍速控制；其下才是常规音轨。 -->
        <Border DockPanel.Dock="Top"
                Background="#17191f"
                BorderBrush="#2a2d36" BorderThickness="0,0,0,1">
            <DockPanel>
                <!-- 速度轨：高度比常规音轨低，仅容纳曲速标签 -->
                <Grid DockPanel.Dock="Top" ColumnDefinitions="170,*" Height="26">
                    <Border Grid.Column="0"
                            Background="#1f222a"
                            BorderBrush="#2a2d36" BorderThickness="0,0,1,1"
                            Padding="6,0">
                        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                            <TextBlock Text="倍速"
                                       VerticalAlignment="Center"
                                       FontSize="11" Foreground="#bcc"/>
                            <NumericUpDown Value="{Binding Speed}" Minimum="0.25" Maximum="4"
                                           Increment="0.25" FormatString="0.00"
                                           Height="22" Width="100"
                                           FontSize="11" Padding="2,0"
                                           VerticalContentAlignment="Center"
                                           ToolTip.Tip="整体演奏倍速：在不改写 BPM 的前提下，按此倍数缩放实际播放速度。"/>
                        </StackPanel>
                    </Border>
                    <ctl:TempoStrip Grid.Column="1"
                                    Name="TempoStripCtl"
                                    Tempos="{Binding Tempos}"
                                    Duration="{Binding Duration}"
                                    Playhead="{Binding Playhead}"/>
                </Grid>

                <!-- 常规音轨缩略图列表 -->
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              MaxHeight="240">
                    <ItemsControl ItemsSource="{Binding Tracks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:MidiTrack">
                            <Grid ColumnDefinitions="170,*" Height="40">
                                <!-- 轨道头：点击只切换轨道，不改变视野 -->
                                <Border Grid.Column="0"
                                        Background="#1f222a"
                                        BorderBrush="#2a2d36" BorderThickness="0,0,1,1"
                                        Padding="8,2"
                                        Tag="{Binding}"
                                        PointerPressed="OnTrackHeadPressed"
                                        Cursor="Hand">
                                    <Grid ColumnDefinitions="Auto,Auto,Auto,*" VerticalAlignment="Center">
                                        <Rectangle Grid.Column="0" Width="4" Height="22"
                                                   VerticalAlignment="Center"
                                                   RadiusX="2" RadiusY="2">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <ToggleButton Grid.Column="1" Classes="trackToggle mute"
                                                      IsChecked="{Binding Muted}"
                                                      Content="M"
                                                      Margin="6,0,2,0"
                                                      ToolTip.Tip="静音此轨道。当存在 Solo 轨道时，被 Solo 的轨道仍会优先于 Mute 演奏。"/>
                                        <ToggleButton Grid.Column="2" Classes="trackToggle solo"
                                                      IsChecked="{Binding Solo}"
                                                      Content="S"
                                                      Margin="0,0,6,0"
                                                      ToolTip.Tip="独奏此轨道。任意一条轨道开启 Solo 后，未 Solo 的轨道都会被屏蔽（即使没有 Mute）。Solo 优先于 Mute。"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12"/>
                                    </Grid>
                                </Border>
                                <!-- 缩略图条 -->
                                <ctl:TrackStrip Grid.Column="1"
                                                Track="{Binding}"
                                                Duration="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).Duration}"
                                                Playhead="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).Playhead}"
                                                ViewportStart="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ViewportStart}"
                                                ViewportEnd="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).ViewportEnd}"
                                                SelectedTrack="{Binding #RootWindow.((vm:MainWindowViewModel)DataContext).SelectedTrack}"
                                                SeekAndActivate="OnStripSeekAndActivate"
                                                ViewportDragTo="OnStripViewportDragTo"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 钢琴卷帘（带倒计时覆盖层） -->
        <Grid>
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Name="RollScroll"
                          PointerWheelChanged="OnRollWheel">
                <ctl:PianoRoll Name="Roll"
                               Notes="{Binding Notes}"
                               Duration="{Binding Duration}"
                               Playhead="{Binding Playhead}"
                               PixelsPerSecond="{Binding PixelsPerSecond}"
                               InstrumentGroup="{Binding SelectedInstrumentGroup}"/>
            </ScrollViewer>

            <!-- 倒计时大字覆盖层，提醒用户切换到原神 -->
            <Border Background="#B0000000"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="12" Padding="32,20"
                    IsVisible="{Binding CountdownText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                    IsHitTestVisible="False">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CountdownText}"
                               Foreground="#ffd250" FontSize="44" FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="请立即切换到原神窗口并打开琴界面"
                               Foreground="#ffffff" FontSize="18"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
